{
  "name": "polymarket-watcher",
  "version": "0.1.0",
  "description": "Autonomous Polymarket monitoring service with AI-powered analysis",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "inngest-cli dev & tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "npx vitest run",
    "test:watch": "npx vitest"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@slack/web-api": "^7.14.1",
    "express": "^4.21.2",
    "inngest": "^3.52.6",
    "ioredis": "^5.4.2",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.9",
    "eslint": "^9.21.0",
    "inngest-cli": "^1.3.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
