# Polymarket Watcher Configuration
# Copy this file to .env and fill in your values

# ===================
# Required Services
# ===================

# Redis connection string
REDIS_URL=redis://localhost:6379

# Inngest configuration
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ===================
# AI Provider (Optional)
# ===================

# Anthropic API key for Claude (optional)
# When not provided, AI classification and whale analysis are disabled.
# The app will still monitor markets and send basic alerts to Slack.
# ANTHROPIC_API_KEY=sk-ant-...

# ===================
# Notifications
# ===================

# Slack bot token for notifications
SLACK_BOT_TOKEN=xoxb-...

# Default Slack channel for alerts
SLACK_DEFAULT_CHANNEL=polymarket-alerts

# ===================
# Application
# ===================

# Environment (development, production)
NODE_ENV=development

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Config file path (relative to project root)
CONFIG_PATH=config/user-config.yaml

# Port for Inngest dev server
PORT=3000
